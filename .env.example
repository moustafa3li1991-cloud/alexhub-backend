MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@alexhub-cluster.xxxxx.mongodb.net/alexhub?retryWrites=true&w=majority
JWT_SECRET=alexhub_super_secret_jwt_key_change_this_in_production
PORT=4000
NODE_ENV=development

# OTP (اختياري - للـ SMS عبر Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Email (اختياري)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Test OTP (للتطوير - لا تغير)
TEST_OTP=111111
